# Copy this file to .env, then replace every placeholder with your own values.
SECRET_KEY=replace-with-a-long-random-django-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Use one Gemini Developer Auth key, or enable the multi-key line below.
# GEMINI_API_KEY=YOUR_GEMINI_AUTH_KEY
GEMINI_API_KEYS=YOUR_GEMINI_AUTH_KEY_1,YOUR_GEMINI_AUTH_KEY_2,YOUR_GEMINI_AUTH_KEY_3
GEMINI_MODEL=gemini-3.5-flash
